---
import Blog from "../components/Blog.astro";
import Separator from "../components/Separator.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Satyaloka</title>
	</head>
	<body>
		<Blog>
			<ul class="w-full flex items-center justify-end gap-8 font-['Faculty'] text-2xl font-bold">
				<li class="hover:underline transition-all hover:text-[--red]"><a href="/home">HOME</a></li>
				<li><a href="/about">ABOUT</a></li>
				<li><a href="/recent">RECENT</a></li>
				<li><a href="/top">TOP</a></li>
			</ul>
    <div class="font-['Busillis'] flex items-center max-h-[200px]">
    <h1 class="text-[200px] text-[--red]">S</h1>
    <h1 class="font-['Busillis'] text-[100px] underline decoration-[--red]">atyaloka</h1>
    </div>
    <div class="flex flex-col gap-2">
    <Separator />
    <Separator />
    </div>
			<slot />
		</Blog>
	</body>
</html>

<style>
	@font-face {
		font-family: "Faculty";		
		src: url("/fonts/FacultyGlyphic-Regular.ttf");
	}

	@font-face {
		font-family: "Busillis";		
		src: url("/fonts/In die busillis.ttf");
	}

	@font-face {
		font-family: "Darwin";		
		src: url("/fonts/DarwinSerif-Regular.ttf");
	}

	:root {
		--background: #061822;		
		--page: #ffe9d7;
		--red: #C41E3A;
	}

	* {
		margin: 0;
		padding: 0;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
